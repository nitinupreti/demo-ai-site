<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
    xmlns:cq="http://www.day.com/jcr/cq/1.0"
    xmlns:jcr="http://www.jcp.org/jcr/1.0"
    xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Tile"
    sling:resourceType="cq/gui/components/authoring/dialog"
    extraClientlibs="[demo-ai-site.components.tile.dialog]">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns">
        <items jcr:primaryType="nt:unstructured">
            <column
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/container">
                <items jcr:primaryType="nt:unstructured">
                    <title
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldLabel="Title"
                        fieldDescription="Tile headline"
                        emptyText="Enter title"
                        name="./title"
                        required="{Boolean}true"/>
                    <description
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldLabel="Description"
                        fieldDescription="Supporting text shown below the title"
                        emptyText="Enter description"
                        name="./description"
                        required="{Boolean}true"/>
                    <backgroundColor
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                        fieldLabel="Background Color"
                        fieldDescription="Choose a preset background color, or select Other to enter a custom hex code"
                        name="./backgroundColor"
                        required="{Boolean}true"
                        granite:class="cmp-tile-dialog__background-color">
                        <items jcr:primaryType="nt:unstructured">
                            <mintGreen
                                jcr:primaryType="nt:unstructured"
                                text="Mint Green"
                                value="mint-green"
                                selected="{Boolean}true"/>
                            <lightBlue
                                jcr:primaryType="nt:unstructured"
                                text="Light Blue"
                                value="light-blue"/>
                            <lightYellow
                                jcr:primaryType="nt:unstructured"
                                text="Light Yellow"
                                value="light-yellow"/>
                            <lightPink
                                jcr:primaryType="nt:unstructured"
                                text="Light Pink"
                                value="light-pink"/>
                            <white
                                jcr:primaryType="nt:unstructured"
                                text="White"
                                value="white"/>
                            <lightGray
                                jcr:primaryType="nt:unstructured"
                                text="Light Gray"
                                value="light-gray"/>
                            <other
                                jcr:primaryType="nt:unstructured"
                                text="Other"
                                value="other"/>
                        </items>
                    </backgroundColor>
                    <backgroundColorHex
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldLabel="Custom Background Hex Code"
                        fieldDescription="Enter a hex color, e.g. #d2f8dc (including the leading #)"
                        emptyText="#RRGGBB"
                        name="./backgroundColorHex"
                        granite:class="cmp-tile-dialog__background-color-hex"/>
                    <margin
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/select"
                        fieldLabel="Margin"
                        fieldDescription="Side on which to apply outer margin"
                        name="./margin"
                        required="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <left
                                jcr:primaryType="nt:unstructured"
                                text="Left"
                                value="left"/>
                            <right
                                jcr:primaryType="nt:unstructured"
                                text="Right"
                                value="right"
                                selected="{Boolean}true"/>
                        </items>
                    </margin>
                    <image
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                        fieldLabel="Image"
                        fieldDescription="Select the tile image from the DAM"
                        name="./image"
                        rootPath="/content/dam"
                        required="{Boolean}true"/>
                    <ctaButtons
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                        composite="{Boolean}true"
                        fieldLabel="CTA Buttons"
                        fieldDescription="Add one or more call-to-action buttons"
                        required="{Boolean}true">
                        <field
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/container"
                            name="./ctaButtons">
                            <items jcr:primaryType="nt:unstructured">
                                <ctaTitle
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    fieldLabel="CTA Title"
                                    emptyText="Enter CTA label"
                                    name="./ctaTitle"
                                    required="{Boolean}true"/>
                                <ctaLink
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                    fieldLabel="CTA Link"
                                    name="./ctaLink"
                                    rootPath="/content"
                                    required="{Boolean}true"/>
                            </items>
                        </field>
                    </ctaButtons>
                </items>
            </column>
        </items>
    </content>
</jcr:root>
